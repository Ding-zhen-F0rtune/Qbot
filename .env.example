# ── OneBot 连接 ──
WS_URL=ws://127.0.0.1:3001
ACCESS_TOKEN=

# ── LLM 配置 ──
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
SYSTEM_PROMPT=你是一个基于QQ聊天的AI助手。你会用自然、友好的语气和用户交流。

# ── 触发与权限 ──
REQUIRE_MENTION=true
# ADMINS=123456,789012
# ALLOWED_GROUPS=111111,222222
# BLOCKED_USERS=
# ADMIN_ONLY_CHAT=false
# KEYWORD_TRIGGERS=小助手,帮我
# AUTO_APPROVE_REQUESTS=false

# ── 消息处理 ──
MAX_MESSAGE_LENGTH=4000
MAX_HISTORY_TURNS=20
# ENABLE_DEDUPLICATION=true
# FORMAT_MARKDOWN=false

# ── 🔍 搜索插件（三选一，配置 Key 即可启用）──
# 推荐 Tavily（免费注册 https://tavily.com）
# TAVILY_API_KEY=tvly-xxxxxxxx

# 或 Bing Search（Azure）
# BING_API_KEY=xxxxxxxx

# 或 Google Custom Search
# GOOGLE_SEARCH_API_KEY=xxxxxxxx
# GOOGLE_SEARCH_CX=xxxxxxxx
